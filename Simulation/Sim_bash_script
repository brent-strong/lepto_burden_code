#!/bin/bash -l
#SBATCH --output=message/output.txt     # job rub mirrow
#SBATCH --error=message/error.txt      # error message
#SBATCH --time=12:00:00                     
#SBATCH --ntasks=4                     
#SBATCH --mem=16g                           
#SBATCH --tmp=16g                           
#SBATCH --mail-type=ALL                    # send email when job aborts/begins/ends
#SBATCH --mail-user=your-email@example.edu # email address to be used
#SBATCH --array=1-3200
#SBATCH -p msismall                        # select partition

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export LEPTO_BURDEN_ROOT="${LEPTO_BURDEN_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
cd "$LEPTO_BURDEN_ROOT/Simulation"
source /etc/profile
module purge
module load udunits/2.2.27.6_gcc11.3.0-rocky8
module load proj/7.2.1-rocky8
module load geos/3.7.1-rocky8
module load gdal/2.3.2-rocky8
module load openssl/3.1.1
module load R/4.4.0-openblas-rocky8

Rscript Simulation_script.R
